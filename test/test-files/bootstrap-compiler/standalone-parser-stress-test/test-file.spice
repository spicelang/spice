f<int> fn0(int a, int b, int c) {
    int acc = 0;
    for int i = 0; i < a; i++ {
        for int j = 0; j < b; j++ {
            if (i + j) % 2 == 0 && i > 0 || j < c {
                acc += i * j - c + (a / 2) * (b - 1);
            } else {
                acc -= (i ^ j) & (a | b);
            }
        }
    }
    int k = 0;
    while k < acc {
        acc = acc - k * 2 + 1;
        k++;
    }
    switch acc % 4 {
        case 0: {
            acc += sizeof<int>();
        }
        case 1, 2: {
            fallthrough;
        }
        case 3: {
            acc -= alignof<long>();
        }
        default: {
            acc = 0;
        }
    }
    bool flag = acc > 0 && a != b || c == 0;
    int result = flag ? acc + a * b - c : acc - a + b * c;
    return result;
}

