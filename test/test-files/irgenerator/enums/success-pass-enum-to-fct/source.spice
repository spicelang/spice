type Fruit enum {
    APPLE,
    BANANA,
    ORANGE,
    KIWI
}

f<Fruit> foo(Fruit fruit) {
    return fruit;
}

f<const Fruit&> bar(const Fruit& fruit) {
    return fruit;
}

f<int> main() {
    Fruit fruit = Fruit::ORANGE;
    Fruit fruit2 = bar(foo(fruit));
    assert fruit == fruit2;
    printf("All assertions passed!");
}