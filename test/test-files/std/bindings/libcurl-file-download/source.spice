import "std/bindings/libcurl/libcurl";
import "std/io/file";

f<int> main() {
    const string url = "https://example.com/file.html";
    const string outputPath = "./file.html";

    CurlClient client;
    Result<string> res = client.downloadFile(url, outputPath);
    if res.isErr() {
        Error& err = res.getErr();
        err.toPanic();
    }
    assert fileExists(outputPath);
    assert isFileReadable(outputPath);

    Result<String> fileContentRes = readFile(outputPath);
    if fileContentRes.isErr() {
        Error& err = fileContentRes.getErr();
        err.toPanic();
    }
    const String fileContent = fileContentRes.unwrap();
    assert fileContent.contains("Example");

    deleteFile(outputPath);

    printf("All assertions passed!\n");
}