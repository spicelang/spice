import "std/data/linked-list";

f<int> main() {
    // 1. Large pushBack: order is preserved
    LinkedList<int> l1;
    for int i = 0; i < 500; i++ { l1.pushBack(i); }
    assert l1.getSize() == 500ul;
    assert l1.getFront() == 0;
    assert l1.getBack() == 499;
    for unsigned long i = 0ul; i < 500ul; i++ {
        assert l1.get(i) == cast<int>(i);
    }

    // 2. Large pushFront: reverses order
    LinkedList<int> l2;
    for int i = 0; i < 200; i++ { l2.pushFront(i); }
    assert l2.getSize() == 200ul;
    assert l2.getFront() == 199;
    assert l2.getBack() == 0;
    for unsigned long i = 0ul; i < 200ul; i++ {
        assert l2.get(i) == 199 - cast<int>(i);
    }

    // 3. insertAt at front, middle, back
    LinkedList<int> l3;
    for int i = 0; i < 4; i++ { l3.pushBack(i); } // 0,1,2,3
    l3.insertAt(0ul, -1);                          // -1,0,1,2,3
    l3.insertAt(3ul, 99);                          // -1,0,1,99,2,3
    l3.insertAt(l3.getSize(), 999);                // -1,0,1,99,2,3,999
    assert l3.getSize() == 7ul;
    assert l3.get(0ul) == -1;
    assert l3.get(3ul) == 99;
    assert l3.get(6ul) == 999;

    // 4. removeAt at front, middle, back
    l3.removeAt(0ul);                              // 0,1,99,2,3,999
    l3.removeAt(2ul);                              // 0,1,2,3,999
    l3.removeAt(l3.getSize() - 1ul);               // 0,1,2,3
    assert l3.getSize() == 4ul;
    for unsigned long i = 0ul; i < 4ul; i++ {
        assert l3.get(i) == cast<int>(i);
    }

    // 5. remove(value) removes only the first match
    LinkedList<int> l4;
    l4.pushBack(1); l4.pushBack(2); l4.pushBack(3); l4.pushBack(2); l4.pushBack(5);
    l4.remove(2);
    assert l4.getSize() == 4ul;
    assert l4.get(0ul) == 1;
    assert l4.get(1ul) == 3;
    assert l4.get(2ul) == 2;
    assert l4.get(3ul) == 5;
    // remove non-existent: no change
    l4.remove(42);
    assert l4.getSize() == 4ul;

    // 6. removeFront / removeBack drain
    LinkedList<int> l5;
    for int i = 0; i < 10; i++ { l5.pushBack(i); }
    while !l5.isEmpty() {
        l5.removeFront();
    }
    assert l5.getSize() == 0ul;
    for int i = 0; i < 10; i++ { l5.pushBack(i); }
    while !l5.isEmpty() {
        l5.removeBack();
    }
    assert l5.getSize() == 0ul;

    // 7. clear then reuse
    LinkedList<int> l6;
    for int i = 0; i < 50; i++ { l6.pushBack(i); }
    l6.clear();
    assert l6.isEmpty();
    for int i = 100; i < 150; i++ { l6.pushBack(i); }
    assert l6.getSize() == 50ul;
    assert l6.getFront() == 100;
    assert l6.getBack() == 149;

    // 8. Iteration via foreach
    LinkedList<int> l7;
    for int i = 0; i < 100; i++ { l7.pushBack(i); }
    int sum = 0;
    foreach int item : l7 { sum += item; }
    assert sum == 99 * 100 / 2;

    // 9. Iteration with index
    int idxSum = 0;
    int valSum = 0;
    foreach unsigned long idx, int item : l7 {
        idxSum += cast<int>(idx);
        valSum += item;
    }
    assert idxSum == valSum;

    printf("LinkedList stress tests passed!\n");
}
