import "std/data/optional";

f<int> main() {
    // 1. Repeated set/clear cycles
    Optional<int> o = Optional<int>();
    for int i = 0; i < 1000; i++ {
        assert !o.isPresent();
        o.set(i);
        assert o.isPresent();
        assert o.get() == i;
        o.clear();
    }
    assert !o.isPresent();

    // 2. Stress equality across many states
    Optional<int> a = Optional<int>();
    Optional<int> b = Optional<int>();
    assert a == b;
    for int i = 0; i < 100; i++ {
        a.set(i);
        b.set(i);
        assert a == b;
        b.set(i + 1);
        assert a != b;
    }

    // 4. Optional<Optional<int>>: nesting
    Optional<Optional<int>> nested = Optional<Optional<int>>();
    assert !nested.isPresent();
    Optional<int> inner = Optional<int>(123);
    nested.set(inner);
    assert nested.isPresent();
    Optional<int>& innerAccess = nested.get();
    assert innerAccess.isPresent();
    assert innerAccess.get() == 123;

    printf("Optional stress tests passed!\n");
}
