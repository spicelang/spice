// Same-file forward declaration + pointer use + full definition.
// The pointer use sandwiched between the forward decl and the full def must be accepted.

forward type Node struct;

p use(Node* n) {
    if n != nil<Node*> {
        printf("got node\n");
    }
}

type Node struct {
    int value
    Node* next
}

f<int> main() {
    Node* root = nil<Node*>;
    use(root);
    printf("ok\n");
}
