type A dyn;

public p printFormat<A>(A element) {
    printf("Sizeof output: %d\n", sizeof(element));
}

public f<A*> getAInc<A>(A* number) {
    (*number)++;
    return number;
}

f<int> main() {
    printFormat(1.123);
    printFormat(543);
    printFormat(["Hello", "World"]);
    int test = 1234;
    printFormat(&test);

    int i = 12;
    int* iPtr = getAInc(&i);
    assert *iPtr == 13;
}