// ===== External type definitions =====
type ExtCurlRef alias byte*;
type CurlOffT alias long;

// ===== External function declarations =====
ext p curl_global_init(long /*flags*/);
ext f<ExtCurlRef> curl_easy_init();
ext f<CurlCode> curl_easy_setopt(ExtCurlRef /*curl*/, CurlOption /*option*/, ...);
ext f<CurlCode> curl_easy_perform(ExtCurlRef /*curl*/);
ext p curl_easy_cleanup(ExtCurlRef /*curl*/);
ext p curl_global_cleanup();

// ===== Generic type defs =====

type OptT long|string|FilePtr;

// ===== CurlClient =====
public type CurlClient struct {
    ExtCurlRef self
}

public p CurlClient.ctor(unsigned long globalInitFlags = CURL_GLOBAL_DEFAULT) {
    curl_global_init(globalInitFlags);
    this.self = curl_easy_init();
}

public p CurlClient.dtor() {
    curl_easy_cleanup(this.self);
    curl_global_cleanup();
}

inline f<bool> CurlClient.isValid() {
    return this.self != nil<ExtCurlRef>;
}

inline p CurlClient.setOption<OptT>(CurlOption option, OptT value) {
    curl_easy_setopt(this.self, option, value);
}

inline f<CurlCode> CurlClient.run() {
    return curl_easy_perform(this.self);
}

public f<Result<string>> CurlClient.downloadFile(string url, string outputPath, bool withProgress = false) {
    // Check if we have a valid curl object
    if !this.isValid() {
        return err<string>("Curl initialization failed");
    }

    // Create + open output file
    const Result<File> fileRes = openFile(outputPath, MODE_READ_WRITE_OVERWRITE);
    if fileRes.isErr() {
        return err<string>(fileRes.getErr());
    }
    const File file = fileRes.unwrap();

    // Set necessary options to CURL
    this.setOption(CurlOption::URL, url);
    this.setOption(CurlOption::FOLLOWLOCATION, 1ul);
    this.setOption(CurlOption::WRITEDATA, file.getRawHandle());
    if withProgress {
        this.setOption(CurlOption::NOPROGRESS, 0ul);
    }

    // Download file
    const CurlCode res = this.run();
    file.close();
    if res != CurlCode::OK {
        return err<string>("Curl returned with error code");
    }

    // Success
    return ok<string>(outputPath);
}
