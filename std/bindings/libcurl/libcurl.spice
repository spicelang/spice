    core.darwin.linker.flag = "`pkg-config --cflags --libs libcurl`",
    core.windows.linker.flag = "-lcurl"
]

// ===== Global constants =====
public const unsigned long CURL_GLOBAL_SSL       = 1ul; // 1 << 0
public const unsigned long CURL_GLOBAL_WIN32     = 2ul; // 1 << 1
public const unsigned long CURL_GLOBAL_ALL       = 3ul; // CURL_GLOBAL_SSL | CURL_GLOBAL_WIN32
public const unsigned long CURL_GLOBAL_NOTHING   = 0ul;
public const unsigned long CURL_GLOBAL_DEFAULT   = 3ul; // CURL_GLOBAL_ALL
public const unsigned long CURL_GLOBAL_ACK_EINTR = 4ul; // 1 << 2

