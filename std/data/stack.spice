// Constants
const unsigned long INITIAL_CAPACITY = 5l;
const unsigned int RESIZE_FACTOR = 2;

// Add generic type definition
type T dyn;

/**
 * A stack in Spice is a commonly used data structure, which uses the FiLo (first in, last out) principle.
 *
 * Time complexity:
 * Insert: O(1)
 * Delete: O(1)
 * Search: O(n)
 *
 * Stacks pre-allocate space using an initial size and a resize factor to not have to re-allocate
 * with every item pushed. A default-constructed stack stays in an unallocated state (contents = nil,
 * capacity = 0) until the first push.
 */
public type Stack<T> struct {
    heap T* contents = nil<heap T*> // Pointer to the first data element; nil while unallocated
    unsigned long capacity = 0l     // Allocated number of items; 0 while unallocated
    unsigned long size = 0l         // Current number of items
}

/**
 * Construct a stack pre-filled with a number of copies of a default value
 *
 * @param initAllocItems Number of items to insert
 * @param defaultValue Value to fill the stack with
 */
public p Stack.ctor(unsigned long initAllocItems, const T &defaultValue) {
    // Allocate space for the initial number of elements
    this.ctor(initAllocItems);
    // Fill in the default values
    for unsigned long index = 0ul; index < initAllocItems; index++ {
        unsafe {
            __placement_new<T>(&this.contents[index], defaultValue);
        }
    }
    this.size = initAllocItems;
}

/**
 * Construct a stack, pre-allocating space for the given number of items
 *
 * @param initAllocItems Number of items to pre-allocate space for
 */
public p Stack.ctor(unsigned int initAllocItems) {
    this.ctor(cast<unsigned long>(initAllocItems));
}

/**
 * Construct a stack, pre-allocating space for the given number of items
 *
 * @param initAllocItems Number of items to pre-allocate space for
 */
public p Stack.ctor(unsigned long initAllocItems = 0l) {
    this.contents = nil<heap T*>;
    this.capacity = 0l;
    this.size = 0l;
    // Leave the buffer unallocated when no capacity was requested
    if initAllocItems == 0l { return; }
    // Allocate space for the initial number of elements
    const unsigned long itemSize = sizeof<T>();
    unsafe {
        Result<heap byte*> allocResult = sAlloc(itemSize * initAllocItems);
        this.contents = cast<heap T*>(allocResult.unwrap());
    }
    this.capacity = initAllocItems;
}

/**
 * Construct a stack as a deep copy of another stack
 *
 * @param original Stack to copy
 */
public p Stack.ctor(const Stack<T>& original) {
    this.ctor(original.capacity);
    if original.size == 0l { return; }
    const unsigned long itemSize = sizeof<T>();
    unsafe {
        sCopy(cast<heap byte*>(original.contents), cast<heap byte*>(this.contents), itemSize * original.size);
    }
    this.size = original.size;
}

/**
 * Copy-assign the contents of another stack into this one
 *
 * @param newValue Stack to copy from
 */
public p operator=<T>(Stack<T>& this, const Stack<T>& newValue) {
    const unsigned long itemSize = sizeof<T>();
    if newValue.capacity != this.capacity {
        if newValue.capacity == 0l {
            // Drop our buffer to match the unallocated source
            unsafe {
                heap byte*& oldAddress = cast<heap byte*>(this.contents);
                sDealloc(oldAddress);
                this.contents = nil<heap T*>;
            }
        } else {
            unsafe {
                Result<heap byte*> allocResult = sRealloc(cast<heap byte*>(this.contents), itemSize * newValue.capacity);
                this.contents = cast<heap T*>(allocResult.unwrap());
            }
        }
        this.capacity = newValue.capacity;
    }
    this.size = newValue.size;
    if newValue.size == 0l { return; }
    unsafe {
        sCopy(cast<heap byte*>(newValue.contents), cast<heap byte*>(this.contents), itemSize * newValue.size);
    }
}

/**
 * Add an item to the stack
 */
public p Stack.push(const T& item) {
    // Check if we need to (re-)allocate memory. Treat an unallocated stack the same as a full one.
    if this.size == this.capacity {
        const unsigned long newCapacity = this.capacity == 0l ? INITIAL_CAPACITY : this.capacity * RESIZE_FACTOR;
        this.resize(newCapacity);
    }

    // Insert the element at the back
    unsafe {
        __placement_new<T>(&this.contents[this.size++], item);
    }
}

/**
 * Retrieve item and remove it from the stack
 */
#[ignoreUnusedReturnValue]
public f<T&> Stack.pop() {
    if this.isEmpty() { panic(Error("The stack is empty")); }
    // Pop the element from the stack
    unsafe {
        return this.contents[--this.size];
    }
}

/**
 * Retrieve topmost without removing it from the stack
 */
public f<T&> Stack.top() {
    if this.isEmpty() { panic(Error("The stack is empty")); }
    // Peek the element from the stack
    unsafe {
        return this.contents[this.size - 1l];
    }
}

/**
 * Retrieve the current size of the stack
 *
 * @return Current size of the stack
 */
public f<long> Stack.getSize() {
    return this.size;
}

/**
 * Retrieve the current capacity of the stack
 *
 * @return Current capacity of the stack
 */
 public f<long> Stack.getCapacity() {
     return this.capacity;
 }

/**
 * Checks if the queue contains any items at the moment
 *
 * @return Empty or not empty
 */
public f<bool> Stack.isEmpty() {
    return this.size == 0;
}

/**
 * Checks if the queue exhausts its capacity and needs to resize at the next call of push.
 * A stack with no allocated capacity is not considered full — the next push will simply
 * bootstrap the buffer.
 *
 * @return Full or not full
 */
public f<bool> Stack.isFull() {
    return this.capacity != 0l && this.size == this.capacity;
}

/**
 * Frees allocated memory that is not used by the queue
 */
public p Stack.pack() {
    // Return if no packing is required
    if this.isFull() { return; }
    // Pack the array
    this.resize(this.size);
}

/**
 * Check if two stacks are equal, i.e. they have the same size and equal contents
 *
 * @return Equal or not equal
 */
public f<bool> operator==<T>(const Stack<T>& lhs, const Stack<T>& rhs) {
    // Compare the sizes
    if lhs.size != rhs.size { return false; }
    // Compare the contents
    const unsigned long itemSize = sizeof<T>();
    return sCompare(lhs.contents, rhs.contents, itemSize * lhs.size);
}

/**
 * Check if two stacks are not equal
 *
 * @return Not equal or equal
 */
public f<bool> operator!=<T>(const Stack<T>& lhs, const Stack<T>& rhs) {
    return !(lhs == rhs);
}

/**
 * Re-allocates heap space for the queue contents
 */
p Stack.resize(unsigned long itemCount) {
    // Free the buffer if we are shrinking down to zero capacity
    if itemCount == 0l {
        unsafe {
            heap byte*& oldAddress = cast<heap byte*>(this.contents);
            sDealloc(oldAddress);
            this.contents = nil<heap T*>;
        }
        this.capacity = 0l;
        return;
    }
    // Allocate the new memory
    const unsigned long itemSize = sizeof<T>();
    unsafe {
        heap byte*& oldAddress = cast<heap byte*>(this.contents);
        unsigned long newSize = cast<unsigned long>(itemSize * itemCount);
        Result<heap byte*> allocResult = sRealloc(oldAddress, newSize);
        this.contents = cast<heap T*>(allocResult.unwrap());
    }
    // Set new capacity
    this.capacity = itemCount;
}