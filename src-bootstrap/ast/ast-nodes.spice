#[test, test.name="ASTNodes Smoke test"]
public f<bool> testASTNodesSmoke() {
    const CodeLoc loc = CodeLoc(3l, 7l, "ast.spice");

    // Base node
    ASTNode base = ASTNode(loc);
    assert base.codeLoc.line == 3l;
    assert base.codeLoc.col == 7l;
    assert base.parent == nil<ASTNode*>;

    // Stmt node composes a base node + carries the 'unreachable' flag
    ASTStmtNode stmt = ASTStmtNode(loc);
    assert stmt.node.codeLoc.line == 3l;
    assert !stmt.unreachable;
    stmt.unreachable = true;
    assert stmt.unreachable;

    // Expression node composes a base node
    ASTExprNode expr = ASTExprNode(loc);
    assert expr.node.codeLoc.col == 7l;

    // Top-level def node composes a base node
    ASTTopLevelDefNode topDef = ASTTopLevelDefNode(loc);
    assert topDef.node.codeLoc.line == 3l;

    // Function-def base composes a top-level def
    ASTFctDefBaseNode fctBase = ASTFctDefBaseNode(loc);
    assert fctBase.node.node.codeLoc.line == 3l;

    // FctDef composes the FctDef-base
    ASTFctDefNode fctDef = ASTFctDefNode(loc);
    assert fctDef.node.node.node.codeLoc.line == 3l;

    // QualifierNode carries a QualifierType
    ASTQualifierNode qual = ASTQualifierNode(loc);
    assert qual.qualifierType == QualifierType::NONE;
    qual.qualifierType = QualifierType::CONST;
    assert qual.qualifierType == QualifierType::CONST;

    // TypeLstWithEllipsisNode
    ASTTypeLstWithEllipsisNode typeLstEllipsis = ASTTypeLstWithEllipsisNode(loc);
    assert typeLstEllipsis.node.codeLoc.line == 3l;

    // TopLevelDefAttrNode
    ASTTopLevelDefAttrNode tlAttr = ASTTopLevelDefAttrNode(loc);
    assert tlAttr.node.codeLoc.line == 3l;

    return true;
}
